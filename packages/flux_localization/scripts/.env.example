# Configuration for AI Translation Dart Script - ./scripts/translate_script.dart

# Main language (used as reference for keys)
MAIN_LANG=en

# AI Service to use for translation
# Options: openai, azure, gemini, grok
AI_TRANSLATE=openai

# Folder containing language files
FOLDER=lib/src/l10n

# OpenAI Configuration
OPENAI_APIKEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4.1

# Azure OpenAI Configuration
# URL format: https://{resource}.openai.azure.com/openai/deployments/{deployment}/chat/completions?api-version=2024-02-01
AZURE_OPENAI_APIKEY=your-azure-openai-api-key-here
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name-here

# Grok Configuration
GROK_APIKEY=your-grok-api-key-here
GROK_BASE_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-beta

# Gemini Configuration
GEMINI_APIKEY=your-gemini-api-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-pro
